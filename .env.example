APP_NAME=MallAgg
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=array

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Gateway / serv-fd (CMS + foundation user). If set, takes precedence over SERV_FD_BASE_URL for the same logical host.
# When the URL contains `://{{service_key}}`, the host is resolved from Redis (paganini); see API_GATEWAY_SD_* below.
API_GATEWAY_BASE_URL=http://nginx:8010
API_GATEWAY_ACCOUNT_RULE_BROKER_USER=rule.backend
API_GATEWAY_ACCOUNT_RULE_BROKER_PASS=12345678
API_GATEWAY_SD_DB_CONN=default
API_GATEWAY_SD_KEY_PREFIX=reg:serv:
API_GATEWAY_SD_MEMO_TTL=60

# Legacy fallback when API_GATEWAY_BASE_URL is unset
SERV_FD_BASE_URL=http://serv-fd:8000
SERV_FD_TIMEOUT_SECONDS=3

# Admin product media uploads use foundation OSS (HTTP PUT), same as Django user avatar.
# Base URL defaults to {SERV_FD_BASE_URL}/api/oss if MALL_OSS_UPLOAD_BASE_URL is unset.
# MALL_OSS_UPLOAD_BASE_URL=http://serv-fd:8000/api/oss
MALL_OSS_BUCKET=mall
MALL_UPLOAD_PREFIX=mall/products

USER_CENTER_ME_ENDPOINT=/api/user/me
USER_CENTER_TIMEOUT_SECONDS=3
USER_CENTER_UNAUTHORIZED_CODE=40101

MALL_CMS_CONTENT_ROUTE=product

# SearchRec (same host as serv-fd if unset). Requires MALL_SEARCHREC_ACCESS_KEY for index + search.
# MALL_SEARCHREC_BASE_URL=http://serv-fd:8000
MALL_SEARCHREC_ACCESS_KEY=
MALL_SEARCHREC_TIMEOUT_SECONDS=5

MALL_AGG_EXECUTION_MODE=serial
MALL_AGG_DEGRADE_STRATEGY=mask_null
MALL_AGG_PARTIAL_FAILURE_CODE=20601
MALL_AGG_PARTIAL_FAILURE_MESSAGE="Partially failed, degraded by aggregator."

VITE_APP_NAME="${APP_NAME}"
