# 分层环境（与 user-agg 一致，见 bootstrap/app.php + paganini LayeredEnvLoader）：
# 1) 先加载项目根目录的 `.env`；
# 2) 仅当 `APP_ENV` 为 dev / test / prod 时，再加载同目录下的 `.env.{APP_ENV}`（如 `APP_ENV=prod` → `.env.prod`），
#    后者覆盖前者中的同名变量。
# 本地开发可保持 `APP_ENV=local`；PHPUnit 使用 `APP_ENV=testing`，均不会加载叠加文件。
APP_NAME=MallAgg
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# log (outbound Http client request/response logs: App\Http\Client\OutboundHttpDebugMiddleware when APP_DEBUG=true)
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=array

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# API gateway host for CMS, user center, OSS, SearchRec (paths unchanged vs service-foundation).
# When the URL contains `://{{service_key}}`, resolve from Redis (paganini); see API_GATEWAY_SD_* below.
API_GATEWAY_BASE_URL=http://nginx:8010
API_GATEWAY_TIMEOUT_SECONDS=3
API_GATEWAY_ACCOUNT_RULE_BROKER_USER=rule.backend
API_GATEWAY_ACCOUNT_RULE_BROKER_PASS=12345678
API_GATEWAY_SD_DB_CONN=default
API_GATEWAY_SD_KEY_PREFIX=reg:serv:
API_GATEWAY_SD_MEMO_TTL=60

# Service Foundation
# CMS
MALL_CMS_CONTENT_ROUTE=product
# OSS
MALL_OSS_BUCKET=mall
MALL_UPLOAD_PREFIX=product
# SearchRec
MALL_SEARCHREC_ACCESS_KEY=

MALL_AGG_EXECUTION_MODE=serial
MALL_AGG_DEGRADE_STRATEGY=mask_null
MALL_AGG_PARTIAL_FAILURE_CODE=20601
MALL_AGG_PARTIAL_FAILURE_MESSAGE="Partially failed, degraded by aggregator."

# Checkout (Saga/TCC orchestration; see config/mall_agg.php)
MALL_CHECKOUT_USE_COORDINATORS=false
MALL_CHECKOUT_USE_TCC_COORDINATOR=false
MALL_INTERNAL_PARTICIPANT_TOKEN=
MALL_SAGA_TIMEOUT_SECONDS=10
MALL_SAGA_PARTICIPANT_ACCESS_KEY=
MALL_SAGA_CHECKOUT_FLOW_ID=0
MALL_TCC_TIMEOUT_SECONDS=15
MALL_TCC_BRANCH_META_POINTS_ID=0
MALL_INVENTORY_OUTBOUND_BASE_URL=
MALL_INVENTORY_OUTBOUND_TIMEOUT_SECONDS=5

VITE_APP_NAME="${APP_NAME}"
