{
  "openapi": "3.0.3",
  "info": {
    "title": "mall-agg 用户端 API",
    "description": "聚合服务对外 HTTP JSON 接口（`routes/api.php`）。业务响应统一为 `ApiResponse` 信封：`data`、`errorCode`、`message`、`_req_id`。成功时 `errorCode` 为 `0`；失败时 `data` 常为空字符串。",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "相对当前站点根路径；完整路径形如 `{origin}/api/...`"
    }
  ],
  "tags": [
    { "name": "MallProducts", "description": "商城商品目录（公开）" },
    { "name": "MallOrders", "description": "商城订单（需 Bearer）" }
  ],
  "paths": {
    "/api/mall/products": {
      "get": {
        "tags": ["MallProducts"],
        "summary": "商品分页列表（含价）",
        "parameters": [
          { "$ref": "#/components/parameters/TraceId" },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "default": 1 },
            "description": "页码，小于 1 时按 1 处理。"
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "maximum": 50, "default": 15 },
            "description": "每页条数，超过 50 时按 50。"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiEnvelope" },
                    {
                      "type": "object",
                      "properties": {
                        "errorCode": { "type": "integer", "example": 0 },
                        "data": { "$ref": "#/components/schemas/ProductListData" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "下游 CMS 不可用或路由不存在等。`errorCode` 如 `40401`。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          }
        }
      }
    },
    "/api/mall/products/{id}": {
      "get": {
        "tags": ["MallProducts"],
        "summary": "商品详情（含价与库存）",
        "parameters": [
          { "$ref": "#/components/parameters/TraceId" },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "minimum": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiEnvelope" },
                    {
                      "type": "object",
                      "properties": {
                        "errorCode": { "type": "integer", "example": 0 },
                        "data": { "$ref": "#/components/schemas/CmsProductItem" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "商品不存在或下游失败。`errorCode` 如 `40401`。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          }
        }
      }
    },
    "/api/mall/orders": {
      "get": {
        "tags": ["MallOrders"],
        "summary": "当前用户订单分页列表",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/TraceId" },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "default": 1 },
            "description": "页码；由 Laravel 分页器从查询串读取，未传时默认第 1 页。"
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "maximum": 50, "default": 15 },
            "description": "每页条数，上限 50。"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiEnvelope" },
                    {
                      "type": "object",
                      "properties": {
                        "errorCode": { "type": "integer", "example": 0 },
                        "data": { "$ref": "#/components/schemas/OrderListData" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["MallOrders"],
        "summary": "创建订单",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/TraceId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateOrderRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "已创建",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiEnvelope" },
                    {
                      "type": "object",
                      "properties": {
                        "errorCode": { "type": "integer", "example": 0 },
                        "data": { "$ref": "#/components/schemas/OrderDetail" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          },
          "422": {
            "description": "校验失败（`errorCode` 如 `100`）或业务规则不满足（`errorCode` 如 `40001`）。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          }
        }
      }
    },
    "/api/mall/orders/{id}": {
      "get": {
        "tags": ["MallOrders"],
        "summary": "订单详情",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/TraceId" },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "minimum": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiEnvelope" },
                    {
                      "type": "object",
                      "properties": {
                        "errorCode": { "type": "integer", "example": 0 },
                        "data": { "$ref": "#/components/schemas/OrderDetail" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          },
          "404": {
            "description": "订单不存在或不属于当前用户。`errorCode` 如 `40401`。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          }
        }
      },
      "patch": {
        "tags": ["MallOrders"],
        "summary": "更新订单状态（迁移）",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/TraceId" },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "minimum": 1 }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateOrderRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiEnvelope" },
                    {
                      "type": "object",
                      "properties": {
                        "errorCode": { "type": "integer", "example": 0 },
                        "data": { "$ref": "#/components/schemas/OrderDetail" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          },
          "404": {
            "description": "订单不存在",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          },
          "422": {
            "description": "校验失败（`errorCode` 如 `100`）、非法状态或非法迁移（`errorCode` 如 `40001`）。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT",
                "description": "先通过基础服务登录取得 `access_token`，请求头：`Authorization: Bearer <access_token>`（Bearer 后单空格）。"
            }
        },
        "parameters": {
            "TraceId": {
                "name": "X-Trace-Id",
                "in": "header",
                "required": false,
                "schema": { "type": "string" },
                "description": "可选链路追踪 ID。"
            }
        },
        "schemas": {
            "ApiEnvelope": {
                "type": "object",
                "required": ["data", "errorCode", "message", "_req_id"],
                "properties": {
                    "data": {
                        "description": "成功时为业务载荷；失败时多为空字符串 `''`。",
                        "oneOf": [
                            { "type": "string" },
                            { "type": "object",
                                "additionalProperties": true
                            },
                            { "type": "array" }
                        ]
                    },
                    "errorCode": {
                        "type": "integer",
                        "description": "业务错误码；`0` 表示成功。"
                    },
                    "message": { "type": "string" },
                    "_req_id": {
                        "type": "string",
                        "description": "请求关联 ID，可能为空字符串。"
                    }
                }
            },
            "CmsProductItem": {
                "type": "object",
                "description": "下游 CMS 商品条目，字段由 CMS 决定；本服务会追加 `price`、`currency`、`stock_quantity`（列表接口仅追加 `price`/`currency`）。",
                "additionalProperties": true,
                "properties": {
                    "id": { "type": "integer",
                        "description": "商品 ID"
                    },
                    "title": { "type": "string" },
                    "description": { "type": "string" },
                    "thumbnail": { "type": "string" },
                    "main_media": { "type": "string" },
                    "ext_media": { "type": "string" },
                    "price": {
                        "type": "integer",
                        "nullable": true,
                        "description": "单价，最小货币单位；无则 `null`。"
                    },
                    "currency": {
                        "type": "string",
                        "example": "MINOR",
                        "description": "固定为 `MINOR`（与 `price` 一致）。"
                    },
                    "stock_quantity": {
                        "type": "integer",
                        "description": "仅详情接口存在；列表接口不包含。"
                    }
                }
            },
            "Pagination": {
                "type": "object",
                "description": "分页由下游 CMS 或 Laravel 分页器提供，键名可能略有差异；此处为常见形态。",
                "additionalProperties": true,
                "properties": {
                    "total": { "type": "integer" },
                    "per_page": { "type": "integer" },
                    "current_page": { "type": "integer" },
                    "last_page": { "type": "integer" }
                }
            },
            "ProductListData": {
                "type": "object",
                "required": ["items", "pagination"],
                "properties": {
                    "items": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/CmsProductItem" }
                    },
                    "pagination": { "$ref": "#/components/schemas/Pagination" }
                }
            },
            "OrderLine": {
                "type": "object",
                "required": ["pid", "quantity", "unit_price"],
                "properties": {
                    "pid": { "type": "integer",
                        "description": "商品 ID"
                    },
                    "quantity": { "type": "integer" },
                    "unit_price": { "type": "integer",
                        "description": "单价（最小货币单位）"
                    }
                }
            },
            "OrderDetail": {
                "type": "object",
                "required": ["id", "uid", "status", "total_price", "ct", "ut", "lines"],
                "properties": {
                    "id": { "type": "integer" },
                    "uid": { "type": "integer",
                        "description": "Foundation 用户 ID"
                    },
                    "status": {
                        "type": "string",
                        "enum": ["pending", "paid", "cancelled"]
                    },
                    "total_price": { "type": "integer" },
                    "ct": { "type": "integer",
                        "description": "创建时间 Unix 时间戳（秒）"
                    },
                    "ut": { "type": "integer",
                        "description": "更新时间 Unix 时间戳（秒）"
                    },
                    "lines": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/OrderLine" }
                    }
                }
            },
            "OrderSummary": {
                "type": "object",
                "required": ["id", "uid", "status", "total_price", "ct", "ut"],
                "properties": {
                    "id": { "type": "integer" },
                    "uid": { "type": "integer" },
                    "status": {
                        "type": "string",
                        "enum": ["pending", "paid", "cancelled"]
                    },
                    "total_price": { "type": "integer" },
                    "ct": { "type": "integer" },
                    "ut": { "type": "integer" }
                }
            },
            "OrderListData": {
                "type": "object",
                "required": ["items", "pagination"],
                "properties": {
                    "items": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/OrderSummary" }
                    },
                    "pagination": { "$ref": "#/components/schemas/Pagination" }
                }
            },
            "CreateOrderRequest": {
                "type": "object",
                "required": ["lines"],
                "properties": {
                    "lines": {
                        "type": "array",
                        "minItems": 1,
                        "items": {
                            "type": "object",
                            "required": ["product_id", "quantity"],
                            "properties": {
                                "product_id": {
                                    "type": "integer",
                                    "minimum": 1
                                },
                                "quantity": {
                                    "type": "integer",
                                    "minimum": 1
                                }
                            }
                        }
                    }
                }
            },
            "UpdateOrderRequest": {
                "type": "object",
                "required": ["status"],
                "properties": {
                    "status": {
                        "type": "string",
                        "description": "订单状态迁移。可用：`pending`、`paid`、`cancelled`；别名：`init`→`pending`，`cancel`→`cancelled`（大小写不敏感）。非法值返回 422。"
                    }
                }
            }
        }
    }
}
