{
  "openapi": "3.0.3",
  "info": {
    "title": "mall-agg 用户端 API",
    "description": "聚合服务对外 HTTP JSON 接口（`routes/api.php`）。业务响应统一为 `ApiResponse` 信封：`data`、`errorCode`、`message`、`_req_id`。成功时 `errorCode` 为 `0`；失败时 `data` 常为空字符串。\n\n**协调式结账**：`POST /api/mall/checkout` 在启用 `MALL_CHECKOUT_USE_COORDINATORS` 时走 Saga/TCC 编排（外部库存预留、积分冻结、支付预创建）；订单 JSON 含 `ext_inventory`、`checkout_phase`、`tid` 等字段。**内部 TCC 参与者**：`POST /internal/tcc/points/*` 由 app_tcc 协调器调用本机积分 Try/Confirm/Cancel，需请求头 `X-Internal-Token`（见 `mall_agg.internal.participant_token`），**不**面向终端用户。**积分余额**：`GET /api/mall/points` 查询当前用户可用积分（`balance_minor`）。\n\n管理后台创建/更新商品时，服务端会**同步**调用下游 SearchRec `POST {API_GATEWAY_BASE_URL}/api/searchrec/index/upsert`（需 `MALL_SEARCHREC_ACCESS_KEY`）。该调用为服务端出站，**不**作为本 OpenAPI 路径对外暴露；请求/响应体见 `service_foundation` 的 `docs/api_searchrec.json`。",
    "version": "1.2.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "相对当前站点根路径；用户端形如 `{origin}/api/...`；内部参与者形如 `{origin}/internal/...`"
    }
  ],
  "tags": [
    { "name": "MallProducts", "description": "商城商品目录（公开）" },
    { "name": "MallOrders", "description": "商城订单（需 `X-User-Access-Token`）" },
    { "name": "MallPoints", "description": "商城积分余额（需 `X-User-Access-Token`；读 `points_balance` 可用余额）" },
    { "name": "MallCheckout", "description": "协调式结账（需 `X-User-Access-Token`；需启用 `MALL_CHECKOUT_USE_COORDINATORS`）" },
    { "name": "InternalTccPoints", "description": "本机积分 TCC 参与者（供协调器调用；需 `X-Internal-Token`）" }
  ],
  "paths": {
    "/api/mall/products": {
      "get": {
        "tags": ["MallProducts"],
        "summary": "商品分页列表（含价）",
        "parameters": [
          { "$ref": "#/components/parameters/TraceId" },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "default": 1 },
            "description": "页码，小于 1 时按 1 处理。"
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "maximum": 50, "default": 15 },
            "description": "每页条数，超过 50 时按 50。"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiEnvelope" },
                    {
                      "type": "object",
                      "properties": {
                        "errorCode": { "type": "integer", "example": 0 },
                        "data": { "$ref": "#/components/schemas/ProductListData" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "下游 CMS 不可用或路由不存在等。`errorCode` 如 `40401`。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          }
        }
      }
    },
    "/api/mall/products/search": {
      "post": {
        "tags": ["MallProducts"],
        "summary": "商品关键词搜索",
        "description": "聚合层将请求转发至下游 SearchRec（`POST …/api/searchrec/search`），服务端注入 `access_key`（环境变量 `MALL_SEARCHREC_ACCESS_KEY`），客户端勿传。未配置 SearchRec 时返回 503（`errorCode` `50301`）。",
        "parameters": [
          { "$ref": "#/components/parameters/TraceId" }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ProductSearchRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功；`data` 为下游检索结果（`items`、`total_hits` 等，与 SearchRec `SearchResult` 对齐）。",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiEnvelope" },
                    {
                      "type": "object",
                      "properties": {
                        "errorCode": { "type": "integer", "example": 0 },
                        "data": { "$ref": "#/components/schemas/ProductSearchResultData" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "422": {
            "description": "请求体验证失败（`errorCode` 如 `1`）。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          },
          "502": {
            "description": "下游 SearchRec 返回业务错误或 HTTP 失败（`errorCode` 如 `50201`）。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          },
          "503": {
            "description": "未配置 SearchRec（缺 `MALL_SEARCHREC_ACCESS_KEY` 或等价配置；`errorCode` `50301`）。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          }
        }
      }
    },
    "/api/mall/products/{id}": {
      "get": {
        "tags": ["MallProducts"],
        "summary": "商品详情（含价与库存）",
        "parameters": [
          { "$ref": "#/components/parameters/TraceId" },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "minimum": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiEnvelope" },
                    {
                      "type": "object",
                      "properties": {
                        "errorCode": { "type": "integer", "example": 0 },
                        "data": { "$ref": "#/components/schemas/CmsProductItem" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "商品不存在或下游失败。`errorCode` 如 `40401`。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          }
        }
      }
    },
    "/api/mall/points": {
      "get": {
        "tags": ["MallPoints"],
        "summary": "当前用户可用积分",
        "description": "返回 Foundation 当前用户在本服务 `points_balance` 表中的可用余额（`balance_minor`，与下单/结账 `points_minor` 同单位）。无账户记录时 `balance_minor` 为 `0`（不自动开户）。",
        "security": [{ "userAccessToken": [] }],
        "parameters": [{ "$ref": "#/components/parameters/TraceId" }],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiEnvelope" },
                    {
                      "type": "object",
                      "properties": {
                        "errorCode": { "type": "integer", "example": 0 },
                        "data": { "$ref": "#/components/schemas/PointsBalanceData" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          }
        }
      }
    },
    "/api/mall/orders": {
      "get": {
        "tags": ["MallOrders"],
        "summary": "当前用户订单分页列表",
        "security": [{ "userAccessToken": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/TraceId" },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "default": 1 },
            "description": "页码；由 Laravel 分页器从查询串读取，未传时默认第 1 页。"
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "maximum": 50, "default": 15 },
            "description": "每页条数，上限 50。"
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiEnvelope" },
                    {
                      "type": "object",
                      "properties": {
                        "errorCode": { "type": "integer", "example": 0 },
                        "data": { "$ref": "#/components/schemas/OrderListData" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["MallOrders"],
        "summary": "创建订单",
        "security": [{ "userAccessToken": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/TraceId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateOrderRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "已创建",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiEnvelope" },
                    {
                      "type": "object",
                      "properties": {
                        "errorCode": { "type": "integer", "example": 0 },
                        "data": { "$ref": "#/components/schemas/OrderDetail" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          },
          "422": {
            "description": "校验失败（`errorCode` 如 `100`）或业务规则不满足（`errorCode` 如 `40001`）。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          }
        }
      }
    },
    "/api/mall/orders/{id}": {
      "get": {
        "tags": ["MallOrders"],
        "summary": "订单详情",
        "security": [{ "userAccessToken": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/TraceId" },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "minimum": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiEnvelope" },
                    {
                      "type": "object",
                      "properties": {
                        "errorCode": { "type": "integer", "example": 0 },
                        "data": { "$ref": "#/components/schemas/OrderDetail" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          },
          "404": {
            "description": "订单不存在或不属于当前用户。`errorCode` 如 `40401`。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          }
        }
      },
      "patch": {
        "tags": ["MallOrders"],
        "summary": "更新订单状态（迁移）",
        "security": [{ "userAccessToken": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/TraceId" },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "minimum": 1 }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateOrderRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiEnvelope" },
                    {
                      "type": "object",
                      "properties": {
                        "errorCode": { "type": "integer", "example": 0 },
                        "data": { "$ref": "#/components/schemas/OrderDetail" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          },
          "404": {
            "description": "订单不存在",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          },
          "422": {
            "description": "校验失败（`errorCode` 如 `100`）、非法状态或非法迁移（`errorCode` 如 `40001`）。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          }
        }
      }
    },
    "/api/mall/checkout": {
      "post": {
        "tags": ["MallCheckout"],
        "summary": "协调式结账（外部库存 + 积分 + 预支付）",
        "description": "需 `MALL_CHECKOUT_USE_COORDINATORS=true`。库存走外部 HTTP 预留；`points_minor>0` 时在本地冻结积分（直连或通过 `MALL_CHECKOUT_USE_TCC_COORDINATOR` 走 TCC 协调器）。未启用协调器时返回 422，`errorCode` `40001`。",
        "security": [{ "userAccessToken": [] }],
        "parameters": [{ "$ref": "#/components/parameters/TraceId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CheckoutRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "已创建订单并完成预支付创建；`data` 含订单快照、`prepay`、`points_tcc_idem_key`（未使用积分时为 `null`）、`tid`（未走 TCC 协调器时多为空字符串）。",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiEnvelope" },
                    {
                      "type": "object",
                      "properties": {
                        "errorCode": { "type": "integer", "example": 0 },
                        "data": { "$ref": "#/components/schemas/CheckoutResponseData" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          },
          "422": {
            "description": "请求体验证失败（`errorCode` `100`）、协调器未启用或业务失败（`errorCode` `40001`）。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          }
        }
      }
    },
    "/internal/tcc/points/try": {
      "post": {
        "tags": ["InternalTccPoints"],
        "summary": "积分 TCC Try（冻结余额）",
        "description": "协调器分支负载；可将业务字段放在 JSON 根上，或使用 `payload` 对象包裹（二者等价，见控制器解析逻辑）。成功与业务失败均返回 HTTP 200，通过 `errorCode` 区分：`0` 成功，`100` 参数或业务错误。",
        "security": [{ "internalToken": [] }],
        "parameters": [{ "$ref": "#/components/parameters/TraceId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TccPointsTryBody" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功时 `errorCode` 为 `0`，`data` 含 `tcc_idem_key`；失败时 `errorCode` 为 `100`。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          },
          "403": {
            "description": "`X-Internal-Token` 缺失或不匹配。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          },
          "503": {
            "description": "未配置 `mall_agg.internal.participant_token`。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          }
        }
      }
    },
    "/internal/tcc/points/confirm": {
      "post": {
        "tags": ["InternalTccPoints"],
        "summary": "积分 TCC Confirm",
        "description": "请求体可为根级 `tcc_idem_key`，或包在 `payload` 内。HTTP 200 + `errorCode` 区分结果。",
        "security": [{ "internalToken": [] }],
        "parameters": [{ "$ref": "#/components/parameters/TraceId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TccPointsIdemBody" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功时 `data` 含 `tcc_idem_key`；失败时 `errorCode` `100`。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          },
          "403": {
            "description": "Token 无效",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          },
          "503": {
            "description": "未配置内部 token",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          }
        }
      }
    },
    "/internal/tcc/points/cancel": {
      "post": {
        "tags": ["InternalTccPoints"],
        "summary": "积分 TCC Cancel（解冻）",
        "description": "请求体同 Confirm。幂等：已回滚或无记录时可成功返回。",
        "security": [{ "internalToken": [] }],
        "parameters": [{ "$ref": "#/components/parameters/TraceId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TccPointsIdemBody" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功时 `data` 含 `tcc_idem_key`；失败时 `errorCode` `100`。",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          },
          "403": {
            "description": "Token 无效",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          },
          "503": {
            "description": "未配置内部 token",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiEnvelope" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
        "securitySchemes": {
            "userAccessToken": {
                "type": "apiKey",
                "in": "header",
                "name": "X-User-Access-Token",
                "description": "基础服务登录返回的 `access_token`（原始 JWT，勿加 `Bearer ` 前缀）。`Authorization: Bearer` 预留给 API 网关；本聚合服务将本头原样透传至用户中心 `/api/user/me`。"
            },
            "internalToken": {
                "type": "apiKey",
                "in": "header",
                "name": "X-Internal-Token",
                "description": "与配置项 `mall_agg.internal.participant_token` 完全一致；未配置时访问内部路由返回 503。"
            }
        },
        "parameters": {
            "TraceId": {
                "name": "X-Trace-Id",
                "in": "header",
                "required": false,
                "schema": { "type": "string" },
                "description": "可选链路追踪 ID。"
            }
        },
        "schemas": {
            "ApiEnvelope": {
                "type": "object",
                "required": ["data", "errorCode", "message", "_req_id"],
                "properties": {
                    "data": {
                        "description": "成功时为业务载荷；失败时多为空字符串 `''`。",
                        "oneOf": [
                            { "type": "string" },
                            { "type": "object",
                                "additionalProperties": true
                            },
                            { "type": "array" }
                        ]
                    },
                    "errorCode": {
                        "type": "integer",
                        "description": "业务错误码；`0` 表示成功。"
                    },
                    "message": { "type": "string" },
                    "_req_id": {
                        "type": "string",
                        "description": "请求关联 ID，可能为空字符串。"
                    }
                }
            },
            "CmsProductItem": {
                "type": "object",
                "description": "下游 CMS 商品条目，字段由 CMS 决定；本服务会追加 `price`、`currency`、`stock_quantity`（列表接口仅追加 `price`/`currency`）。",
                "additionalProperties": true,
                "properties": {
                    "id": { "type": "integer",
                        "description": "商品 ID"
                    },
                    "title": { "type": "string" },
                    "description": { "type": "string" },
                    "thumbnail": { "type": "string" },
                    "main_media": { "type": "string" },
                    "ext_media": { "type": "string" },
                    "price": {
                        "type": "integer",
                        "nullable": true,
                        "description": "单价，最小货币单位；无则 `null`。"
                    },
                    "currency": {
                        "type": "string",
                        "example": "MINOR",
                        "description": "固定为 `MINOR`（与 `price` 一致）。"
                    },
                    "stock_quantity": {
                        "type": "integer",
                        "description": "仅详情接口存在；列表接口不包含。"
                    }
                }
            },
            "Pagination": {
                "type": "object",
                "description": "分页由下游 CMS 或 Laravel 分页器提供，键名可能略有差异；此处为常见形态。",
                "additionalProperties": true,
                "properties": {
                    "total": { "type": "integer" },
                    "per_page": { "type": "integer" },
                    "current_page": { "type": "integer" },
                    "last_page": { "type": "integer" }
                }
            },
            "ProductListData": {
                "type": "object",
                "required": ["items", "pagination"],
                "properties": {
                    "items": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/CmsProductItem" }
                    },
                    "pagination": { "$ref": "#/components/schemas/Pagination" }
                }
            },
            "OrderLine": {
                "type": "object",
                "required": ["pid", "quantity", "unit_price"],
                "properties": {
                    "pid": { "type": "integer",
                        "description": "商品 ID"
                    },
                    "quantity": { "type": "integer" },
                    "unit_price": { "type": "integer",
                        "description": "单价（最小货币单位）"
                    }
                }
            },
            "PointsBalanceData": {
                "type": "object",
                "required": ["balance_minor"],
                "properties": {
                    "balance_minor": {
                        "type": "integer",
                        "minimum": 0,
                        "description": "当前可用积分（最小单位，与结账 `points_minor` 一致）。"
                    }
                }
            },
            "OrderDetail": {
                "type": "object",
                "required": ["id", "uid", "status", "total_price", "ct", "ut", "lines"],
                "properties": {
                    "id": { "type": "integer" },
                    "uid": { "type": "integer",
                        "description": "Foundation 用户 ID"
                    },
                    "status": {
                        "type": "integer",
                        "enum": [0, 1, 2],
                        "description": "0=pending，1=paid，2=cancelled"
                    },
                    "total_price": { "type": "integer" },
                    "ct": { "type": "integer",
                        "description": "创建时间 Unix 时间戳（秒）"
                    },
                    "ut": { "type": "integer",
                        "description": "更新时间 Unix 时间戳（秒）"
                    },
                    "lines": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/OrderLine" }
                    }
                }
            },
            "OrderSummary": {
                "type": "object",
                "required": ["id", "uid", "status", "total_price", "ct", "ut"],
                "properties": {
                    "id": { "type": "integer" },
                    "uid": { "type": "integer" },
                    "status": {
                        "type": "integer",
                        "enum": [0, 1, 2],
                        "description": "0=pending，1=paid，2=cancelled"
                    },
                    "total_price": { "type": "integer" },
                    "ct": { "type": "integer" },
                    "ut": { "type": "integer" }
                }
            },
            "OrderListData": {
                "type": "object",
                "required": ["items", "pagination"],
                "properties": {
                    "items": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/OrderSummary" }
                    },
                    "pagination": { "$ref": "#/components/schemas/Pagination" }
                }
            },
            "CreateOrderRequest": {
                "type": "object",
                "required": ["lines"],
                "properties": {
                    "lines": {
                        "type": "array",
                        "minItems": 1,
                        "items": {
                            "type": "object",
                            "required": ["product_id", "quantity"],
                            "properties": {
                                "product_id": {
                                    "type": "integer",
                                    "minimum": 1
                                },
                                "quantity": {
                                    "type": "integer",
                                    "minimum": 1
                                }
                            }
                        }
                    }
                }
            },
            "UpdateOrderRequest": {
                "type": "object",
                "required": ["status"],
                "properties": {
                    "status": {
                        "oneOf": [
                            { "type": "integer", "enum": [0, 1, 2] },
                            { "type": "string", "description": "与整数等价：`pending`、`paid`、`cancelled`；别名：`init`→pending，`cancel`→cancelled（大小写不敏感）。也可传数字字符串如 `\"1\"`。" }
                        ],
                        "description": "目标状态：0=pending，1=paid，2=cancelled。字符串或整数均可；非法值返回 422。"
                    }
                }
            },
            "ProductSearchRequest": {
                "type": "object",
                "description": "对应下游 `SearchRequest` 中可由客户端提供的字段；`access_key` 由聚合层追加。",
                "properties": {
                    "query": {
                        "type": "string",
                        "maxLength": 2000,
                        "description": "查询串；可省略或空字符串。"
                    },
                    "top_k": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 100,
                        "default": 10,
                        "description": "返回条数上限；未传时默认 10。"
                    },
                    "preferred_tags": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "maxLength": 200
                        },
                        "description": "偏好标签列表；空串元素会被忽略。"
                    }
                }
            },
            "SearchHitItem": {
                "type": "object",
                "description": "与下游 SearchRec `SearchHit` 一致；可能含 `features` 等扩展字段。",
                "additionalProperties": true,
                "properties": {
                    "id": { "type": "string" },
                    "title": { "type": "string" },
                    "tags": {
                        "type": "array",
                        "items": { "type": "string" }
                    },
                    "score": { "type": "number" }
                }
            },
            "ProductSearchResultData": {
                "type": "object",
                "required": ["items", "total_hits"],
                "description": "与下游 SearchRec `SearchResult` 对齐。",
                "properties": {
                    "items": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/SearchHitItem" }
                    },
                    "total_hits": { "type": "integer" }
                }
            },
            "CheckoutRequest": {
                "type": "object",
                "required": ["lines"],
                "properties": {
                    "lines": {
                        "type": "array",
                        "minItems": 1,
                        "items": {
                            "type": "object",
                            "required": ["product_id", "quantity"],
                            "properties": {
                                "product_id": { "type": "integer", "minimum": 1 },
                                "quantity": { "type": "integer", "minimum": 1 }
                            }
                        }
                    },
                    "points_minor": {
                        "type": "integer",
                        "minimum": 0,
                        "description": "使用积分抵扣的额度（最小单位），未传或 `0` 表示不用积分。"
                    }
                }
            },
            "CheckoutOrderDetail": {
                "type": "object",
                "required": ["id", "uid", "status", "total_price", "ct", "ut", "lines", "ext_inventory", "checkout_phase", "tid"],
                "description": "`POST /api/mall/checkout` 返回的订单快照，在普通 `OrderDetail` 基础上增加协调器相关字段。",
                "properties": {
                    "id": { "type": "integer" },
                    "uid": { "type": "integer", "description": "Foundation 用户 ID" },
                    "status": {
                        "type": "integer",
                        "enum": [0, 1, 2],
                        "description": "0=pending，1=paid，2=cancelled"
                    },
                    "total_price": { "type": "integer" },
                    "ct": { "type": "integer", "description": "创建时间 Unix 秒" },
                    "ut": { "type": "integer", "description": "更新时间 Unix 秒" },
                    "lines": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/OrderLine" }
                    },
                    "ext_inventory": {
                        "type": "boolean",
                        "description": "是否使用外部库存预留（协调式结账路径为 `true`）。"
                    },
                    "checkout_phase": {
                        "type": "integer",
                        "description": "结账阶段枚举 `CheckoutPhase` 的整数值：0=None，10=CoordinatorStarted，20=InventoryReserved，30=OrderCreated，40=PointsTryPending，50=AwaitPayment，60=Completed。"
                    },
                    "tid": {
                        "type": "string",
                        "description": "TCC 全局事务 id（协调器下发）；未参与 TCC 时为空字符串。"
                    }
                }
            },
            "PrepayStub": {
                "type": "object",
                "description": "当前占位实现 `StubPaymentOutboundClient` 返回；真实支付网关替换后字段以契约为准。",
                "properties": {
                    "order_id": { "type": "integer" },
                    "amount_minor": { "type": "integer" },
                    "uid": { "type": "integer" },
                    "status": { "type": "string", "example": "stub_await_payment" }
                }
            },
            "CheckoutResponseData": {
                "type": "object",
                "required": ["order", "prepay", "points_tcc_idem_key", "tid"],
                "properties": {
                    "order": { "$ref": "#/components/schemas/CheckoutOrderDetail" },
                    "prepay": { "$ref": "#/components/schemas/PrepayStub" },
                    "points_tcc_idem_key": {
                        "type": "string",
                        "nullable": true,
                        "description": "本单积分分支的 TCC 幂等键；未使用积分时为 `null`。"
                    },
                    "tid": {
                        "type": "string",
                        "description": "与 `order.tid` 一致；来自 TCC 协调器的全局事务 id。"
                    }
                }
            },
            "TccPointsTryPayload": {
                "type": "object",
                "required": ["uid", "amount_minor", "tcc_idem_key"],
                "properties": {
                    "uid": { "type": "integer", "minimum": 1, "description": "Foundation 用户 ID" },
                    "amount_minor": { "type": "integer", "minimum": 1, "description": "冻结积分数量（最小单位）" },
                    "order_id": { "type": "integer", "minimum": 1, "description": "可选，关联订单 id" },
                    "tcc_idem_key": { "type": "string", "minLength": 1, "description": "TCC 幂等键（与 `points_flow.tcc_idem_key` 对应）" }
                }
            },
            "TccPointsTryBody": {
                "oneOf": [
                    { "$ref": "#/components/schemas/TccPointsTryPayload" },
                    {
                        "type": "object",
                        "required": ["payload"],
                        "properties": {
                            "payload": { "$ref": "#/components/schemas/TccPointsTryPayload" }
                        }
                    }
                ],
                "description": "根级字段与 `payload` 包裹二选一（见实现解析）。"
            },
            "TccPointsIdemPayload": {
                "type": "object",
                "required": ["tcc_idem_key"],
                "properties": {
                    "tcc_idem_key": { "type": "string", "minLength": 1 }
                }
            },
            "TccPointsIdemBody": {
                "oneOf": [
                    { "$ref": "#/components/schemas/TccPointsIdemPayload" },
                    {
                        "type": "object",
                        "required": ["payload"],
                        "properties": {
                            "payload": { "$ref": "#/components/schemas/TccPointsIdemPayload" }
                        }
                    }
                ]
            }
        }
    }
}
